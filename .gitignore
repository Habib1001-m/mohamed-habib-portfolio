# Dependencies and package-manager state
/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js and generic build output
/.next/
/out/
/build/
/dist/

# TypeScript, framework, and tool caches
*.tsbuildinfo
/next-env.d.ts
/.turbo/
/.cache/
.eslintcache

# Tests, coverage, and generated QA output
/coverage/
/playwright-report/
/test-results/
/blob-report/
/screenshots/
/qa-artifacts/

# Environment files, credentials, and certificates
.env
.env.*
!.env.example
*.pem

# Logs and diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editors, operating systems, and downloaded-file metadata
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
*:Zone.Identifier
/.vscode/
/.idea/

# Deployment metadata
/.vercel/

# Internal documentation and agent context — never publish
/docs/
/.agents/
/.codex/
/.claude/
/.cursor/
/worklog.md
/worklog_*.md
/*_worklog.md
/AGENT*.md
/PRODUCT.md
/DESIGN.md
/PRODUCT.local.md
/DESIGN.local.md

# Scratch files, temporary exports, and patch leftovers
/.scratch/
/scratch/
/tmp/
/temp/
/artifacts/
/reports/
*.tmp
*.bak
*.orig
*.rej
/*.diff
/*.patch

# Explicitly excluded foreign or placeholder public assets
/public/logo.svg
